#include<stdio.h>
#include<stdlib.h>
int main(){
char n;
printf("Enter a single character: ");
scanf("%c",&n);
if((n>='A')&&(n<='Z')){
printf("Uppercase alphabet");
}
else if((n>='a')&&(n<='z')){
printf("Lowercase alphabet");
}
else if((n>='0')&&(n<='9ds')){
printf("Digit");
}
else{
printf("Special symbol");
}
return 0;
}
